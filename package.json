{
  "name": "codeboxx-website",
  "version": "1.0.0",
  "description": "The Codeboxx Eleventy website.",
  "main": ".eleventy.js",
  "scripts": {
    "start": "npx @11ty/eleventy --serve",
    "build": "ELEVENTY_ENV=production npx @11ty/eleventy",
    "postbuild": "node scripts/minify-dist-css.js",
    "add:blog": "node scripts/add-feature.js blog",
    "add:changelog": "node scripts/add-feature.js changelog",
    "add:faqs": "node scripts/add-feature.js faqs",
    "add:portfolio": "node scripts/add-feature.js portfolio",
    "add:team": "node scripts/add-feature.js team"
  },
  "keywords": [
    "eleventy",
    "11ty",
    "netlify-cms",
    "thermal-printheads",
    "thermal-transfer-ribbons"
  ],
  "license": "MIT",
  "dependencies": {
    "@11ty/eleventy-plugin-rss": "^1.0.7",
    "js-yaml": "^4.1.0",
    "luxon": "^3.6.1",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "lightningcss": "^1.32.0"
  }
}
